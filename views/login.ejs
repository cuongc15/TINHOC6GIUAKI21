<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập - Exam Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
    <div class="bg-white p-8 rounded-lg shadow-md w-96">
        <h2 id="form-title" class="text-2xl font-bold text-center mb-6 text-blue-600">Đăng Nhập</h2>
        <form class="space-y-4" onsubmit="event.preventDefault(); window.location.href='/teacher/dashboard'">
            <div id="role-select" class="hidden">
                <label class="block text-sm font-medium mb-1">Bạn là:</label>
                <select class="w-full border p-2 rounded">
                    <option value="student">Học sinh</option>
                    <option value="teacher">Giáo viên</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Email</label>
                <input type="email" placeholder="Nhập email..." class="w-full border p-2 rounded" required />
            </div>
            <div>
                <label class="block text-sm font-medium mb-1">Mật khẩu</label>
                <input type="password" placeholder="Nhập mật khẩu..." class="w-full border p-2 rounded" required />
            </div>
            <button type="submit" id="submit-btn" class="w-full bg-blue-600 text-white p-2 rounded font-bold hover:bg-blue-700">
                Đăng Nhập
            </button>
        </form>
        <p class="mt-4 text-center text-sm">
            <span id="toggle-text">Chưa có tài khoản? </span>
            <span class="text-blue-600 cursor-pointer font-semibold" onclick="toggleMode()">Đăng ký ngay</span>
        </p>
    </div>

    <script>
        let isLogin = true;
        function toggleMode() {
            isLogin = !isLogin;
            document.getElementById('form-title').innerText = isLogin ? "Đăng Nhập" : "Đăng Ký Tài Khoản";
            document.getElementById('role-select').classList.toggle('hidden', isLogin);
            document.getElementById('submit-btn').innerText = isLogin ? "Đăng Nhập" : "Đăng Ký";
            document.getElementById('toggle-text').innerText = isLogin ? "Chưa có tài khoản? " : "Đã có tài khoản? ";
            document.querySelector('.text-blue-600.cursor-pointer').innerText = isLogin ? "Đăng ký ngay" : "Đăng nhập";
        }
    </script>
</body>
</html>
